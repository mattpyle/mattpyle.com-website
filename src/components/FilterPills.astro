---
interface Pill {
  value: string;
  label: string;
}

interface Props {
  pills: Pill[];
  groupLabel: string;
  /** CSS selector (relative to the document) for the items this filter shows/hides. */
  itemSelector: string;
  /** Name of the `data-*` attribute on each item to read and match against a pill's value. */
  itemDataAttr: string;
  /** 'list' reads the attribute as a comma-separated list (any match); 'exact' requires equality. */
  matchMode: 'list' | 'exact';
  noun: string;
  nounPlural: string;
  /** Connective phrase for the live-region sentence, e.g. "tagged" or "with status". */
  filterVerb: string;
}

const { pills, groupLabel, itemSelector, itemDataAttr, matchMode, noun, nounPlural, filterVerb } = Astro.props;
---

<div
  class="filter-pills"
  role="group"
  aria-label={groupLabel}
  data-item-selector={itemSelector}
  data-item-attr={itemDataAttr}
  data-match-mode={matchMode}
  data-noun={noun}
  data-noun-plural={nounPlural}
  data-filter-verb={filterVerb}
>
  {pills.map((pill, i) => (
    <button class="filter-pill" class:list={{ 'is-active': i === 0 }} data-value={pill.value} aria-current={i === 0 ? 'true' : undefined}>
      {pill.label}
    </button>
  ))}
</div>
<p class="filter-status" aria-live="polite"></p>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.filter-pills').forEach(group => {
      const buttons = group.querySelectorAll<HTMLButtonElement>('.filter-pill');
      const status = group.nextElementSibling as HTMLElement | null;
      const itemSelector = group.dataset.itemSelector!;
      const itemAttr = group.dataset.itemAttr!;
      const matchMode = group.dataset.matchMode;
      const noun = group.dataset.noun!;
      const nounPlural = group.dataset.nounPlural!;
      const filterVerb = group.dataset.filterVerb!;
      const items = document.querySelectorAll<HTMLElement>(itemSelector);
      if (!buttons.length || !status) return;

      buttons.forEach(btn => {
        btn.addEventListener('click', () => {
          const value = btn.dataset.value!;
          buttons.forEach(b => {
            b.classList.remove('is-active');
            b.removeAttribute('aria-current');
          });
          btn.classList.add('is-active');
          btn.setAttribute('aria-current', 'true');

          let visible = 0;
          items.forEach(item => {
            const raw = item.dataset[itemAttr] ?? '';
            const matches = value === 'all' || (matchMode === 'list' ? raw.split(',').includes(value) : raw === value);
            item.hidden = !matches;
            if (matches) visible++;
          });

          const label = btn.textContent ?? '';
          const nounFor = (n: number) => (n === 1 ? noun : nounPlural);
          if (visible === 0) {
            status.textContent = `No ${nounPlural} ${filterVerb} ${label} yet.`;
          } else if (value === 'all') {
            status.textContent = `Showing all ${visible} ${nounFor(visible)}.`;
          } else {
            status.textContent = `Showing ${visible} ${nounFor(visible)} ${filterVerb} ${label}.`;
          }
        });
      });
    });
  });
</script>

<style>
  .filter-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 20px;
  }

  .filter-pill {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-muted);
    border: 1px solid var(--color-border);
    background: transparent;
    padding: 5px 12px;
    border-radius: 999px;
    cursor: pointer;
    transition: background .15s ease, color .15s ease, border-color .15s ease;
  }

  .filter-pill:hover { color: var(--color-accent); border-color: var(--color-accent); }
  .filter-pill.is-active { background: var(--color-accent); color: var(--color-bg); border-color: var(--color-accent); }

  .filter-status {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
</style>
