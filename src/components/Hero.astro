---
import ActivityLog from './ActivityLog.astro';

interface ActivityItem {
  date: Date;
  verb: string;
  label: string;
}

interface Props {
  activityItems: ActivityItem[];
}

const { activityItems } = Astro.props;
---

<section data-module="hero">
  <div class="hero-copy">
    <p class="hero-eyebrow">Growth &amp; PLG, in public</p>
    <h1>Matt Pyle</h1>
    <p class="hero-tagline">I think about growth, write about marketing, and build things that sometimes work.</p>
    <p class="hero-role">Director of Growth · Temporal Technologies</p>
    <div class="hero-ctas">
      <a href="/writing" class="cta-primary">Read the writing</a>
      <a href="/builds" class="cta-secondary">See the builds →</a>
    </div>
  </div>
  <div class="hero-log">
    <ActivityLog items={activityItems} />
  </div>
</section>

<style>
  [data-module="hero"] {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 48px;
    padding: 72px var(--gutter) 56px;
    max-width: var(--width-shell);
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .16em;
    color: var(--color-label);
    margin: 0 0 20px;
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 52px;
    line-height: 1.05;
    color: var(--color-heading);
    margin: 0 0 24px;
  }

  .hero-tagline {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 18.5px;
    line-height: 1.65;
    color: #4a4436;
    max-width: 460px;
    margin: 0 0 12px;
  }

  .hero-role {
    font-size: 13.5px;
    color: var(--color-muted);
    line-height: 1.7;
    max-width: 460px;
    margin: 0 0 30px;
  }

  .hero-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
  }

  .cta-primary {
    padding: 10px 18px;
    border: 1px solid var(--color-accent);
    border-radius: 999px;
    font-size: 12.5px;
    color: var(--color-accent);
    transition: background .15s ease, color .15s ease;
  }

  .cta-primary:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .cta-secondary {
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 12.5px;
    color: var(--color-muted);
  }

  .cta-secondary:hover { color: var(--color-accent); }

  @media (max-width: 860px) {
    [data-module="hero"] {
      grid-template-columns: 1fr;
      gap: 32px;
      padding-top: 56px;
    }
    .hero-log { order: 2; }
  }

  @media (max-width: 600px) {
    [data-module="hero"] { padding: 40px var(--gutter-mobile) 40px; }
    h1 { font-size: 40px; }
  }
</style>
