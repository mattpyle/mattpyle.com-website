---
/**
 * Dismissible aria-live confirmation shown whenever the appearance changes
 * (from the footer toggle, the banner's exit button, or the set_appearance
 * WebMCP tool). Announces the change to screen readers and offers a one-click
 * way back — the second of the two always-present exits from retro mode.
 */
---

<div id="appearance-toast" class="appearance-toast" role="status" aria-live="polite" hidden>
  <span id="appearance-toast-message"></span>
  <button type="button" id="appearance-toast-dismiss" aria-label="Dismiss notification">&times;</button>
</div>

<style>
  .appearance-toast {
    position: fixed;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 50;
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 10px 16px;
    background: var(--color-heading);
    color: var(--color-bg);
    border-radius: 8px;
    font-family: var(--font-system);
    font-size: 13px;
    box-shadow: 0 4px 16px rgba(0, 0, 0, .2);
  }

  .appearance-toast[hidden] {
    display: none;
  }

  #appearance-toast-dismiss {
    background: none;
    border: none;
    color: inherit;
    font-size: 16px;
    line-height: 1;
    cursor: pointer;
    padding: 0 2px;
  }
</style>
