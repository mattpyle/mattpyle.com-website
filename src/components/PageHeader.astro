---
interface Props {
  eyebrow: string;
  title: string;
  subtitle: string;
  wide?: boolean;
}

const { eyebrow, title, subtitle, wide = false } = Astro.props;
---

<header data-module="page-header" class:list={{ 'is-wide': wide }}>
  <p class="header-eyebrow">{eyebrow}</p>
  <h1>{title}</h1>
  <p class="header-subtitle">{subtitle}</p>
</header>

<style>
  [data-module="page-header"] {
    max-width: 820px;
    margin: 0 auto;
    padding: 64px 40px 12px;
  }

  [data-module="page-header"].is-wide {
    max-width: 1080px;
  }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .16em;
    color: var(--color-label);
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  h1 {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 44px;
    line-height: 1.05;
    color: var(--color-heading);
    margin: 0 0 14px;
  }

  .header-subtitle {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 16.5px;
    color: var(--color-muted);
    margin: 0 0 32px;
  }

  @media (max-width: 600px) {
    [data-module="page-header"] { padding: 40px 20px 8px; }
    h1 { font-size: 34px; }
  }
</style>
