---
interface Entry {
  id: string;
  data: {
    title: string;
    summary: string;
    date: Date;
    type: string;
    significance: 'major' | 'minor' | 'patch';
    tags: string[];
  };
}

interface Props {
  entries: Entry[];
}

const { entries } = Astro.props;

function formatDate(date: Date): string {
  const d = date.getUTCDate().toString().padStart(2, '0');
  const m = date.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const y = date.getUTCFullYear();
  return `${d} ${m} ${y}`;
}

// Entries arrive newest-first (already sliced to the current page); group them by
// year, preserving that order. A year that spans a page boundary simply repeats its
// rule on the next page — expected.
const groups: { year: number; items: Entry[] }[] = [];
for (const entry of entries) {
  const year = entry.data.date.getUTCFullYear();
  const group = groups.at(-1);
  if (group && group.year === year) group.items.push(entry);
  else groups.push({ year, items: [entry] });
}
---

<div data-module="changelog-ledger">
  {groups.map(group => (
    <>
      <div class="year-rule">
        <span class="year-label">{group.year}</span>
        <span class="year-line" aria-hidden="true"></span>
      </div>
      {group.items.map(entry => (
        <a href={`/changelog/${entry.id}`} class="lg-row">
          <div class="lg-when">
            <span class={`sig-dot sig-dot--${entry.data.significance}`} aria-hidden="true"></span>
            <span class="lg-date">{formatDate(entry.data.date)}</span>
          </div>
          <div class="lg-main">
            <div class="lg-title">{entry.data.title}</div>
            <p class="lg-summary">{entry.data.summary}</p>
            <div class="lg-tags lg-tags--mobile">
              <span class="type-pill">{entry.data.type}</span>
              {entry.data.tags.map(tag => <span class="tag-pill">{tag}</span>)}
            </div>
          </div>
          <div class="lg-tags lg-tags--desktop">
            <span class="type-pill">{entry.data.type}</span>
            {entry.data.tags.map(tag => <span class="tag-pill">{tag}</span>)}
          </div>
        </a>
      ))}
    </>
  ))}
</div>

<style>
  /* ── Year rule ──────────────────────────────────────────────────────────── */
  .year-rule {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 18px 0 8px;
  }

  .year-label {
    font-family: var(--font-mono);
    font-size: 12px;
    letter-spacing: .14em;
    font-weight: 600;
    color: var(--color-heading);
  }

  .year-line {
    flex: 1;
    height: 1px;
    background: var(--color-border);
  }

  /* ── Row ────────────────────────────────────────────────────────────────── */
  .lg-row {
    display: grid;
    grid-template-columns: 132px 1fr auto;
    gap: 0 20px;
    align-items: start;
    padding: 13px 12px;
    margin: 0 -12px;
    border-radius: 6px;
    text-decoration: none;
    transition: background .12s ease;
  }

  .lg-row:hover { background: var(--color-accent-wash); }
  .lg-row:hover .lg-title { color: var(--color-accent); }

  .lg-when {
    display: flex;
    align-items: center;
    gap: 10px;
    padding-top: 3px;
  }

  .sig-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .sig-dot--major { background: var(--color-sig-major); }
  .sig-dot--minor { background: var(--color-sig-minor); }
  .sig-dot--patch { background: var(--color-sig-patch); }

  .lg-date {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .06em;
    color: var(--color-label);
    white-space: nowrap;
  }

  .lg-main { min-width: 0; }

  .lg-title {
    font-family: var(--font-serif);
    font-size: 17px;
    font-weight: 600;
    line-height: 1.3;
    color: var(--color-heading);
    transition: color .12s ease;
  }

  .lg-summary {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-muted);
    margin: 3px 0 0;
  }

  /* ── Tag clusters ───────────────────────────────────────────────────────── */
  .lg-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .lg-tags--desktop {
    justify-content: flex-end;
    max-width: 220px;
    padding-top: 3px;
  }

  .lg-tags--mobile {
    display: none;
    margin-top: 2px;
  }

  .type-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid rgba(122, 46, 46, .25);
    padding: 2px 8px;
    border-radius: 999px;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-label);
    border: 1px solid var(--color-border);
    padding: 2px 8px;
    border-radius: 999px;
  }

  /* ── Mobile: 3-col grid → stacked flex ──────────────────────────────────── */
  @media (max-width: 600px) {
    .lg-row {
      display: flex;
      flex-direction: column;
      gap: 9px;
      padding: 15px 12px;
    }

    .lg-when { padding-top: 0; }
    .lg-tags--desktop { display: none; }
    .lg-tags--mobile { display: flex; }
  }
</style>
