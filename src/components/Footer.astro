---
const year = new Date().getFullYear();
---

<footer data-module="footer">
  <nav aria-label="Social links">
    <a href="/rss.xml" class="rss-link" aria-label="RSS feed for Writing">
      <svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true" focusable="false">
        <path fill="currentColor" d="M4 11a9 9 0 0 1 9 9h-2.5A6.5 6.5 0 0 0 4 13.5V11zm0 6.5a2.5 2.5 0 1 1 0 5 2.5 2.5 0 0 1 0-5zM4 4a16 16 0 0 1 16 16h-2.5A13.5 13.5 0 0 0 4 6.5V4z"/>
      </svg>
      RSS
    </a>
    <a href="https://github.com/mattpyle" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://linkedin.com/in/matt-pyle" target="_blank" rel="noopener noreferrer">LinkedIn</a>
    <button type="button" class="appearance-toggle" data-appearance-toggle aria-pressed="false">
      Retro mode
    </button>
  </nav>
  <p class="retro-footer-badges" aria-hidden="true">
    <span>[ Handcrafted ]</span>
    <span>[ No framework ]</span>
    <span>[ Human + agent readable ]</span>
  </p>
  <p>© {year} Matt Pyle</p>
</footer>

<style>
  [data-module="footer"] {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px var(--gutter);
    border-top: 1px solid var(--color-border);
    width: 100%;
    max-width: var(--width-shell);
    margin: 0 auto;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a {
    font-size: 11px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color .15s ease;
  }

  nav a:hover { color: var(--color-accent); }

  .rss-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  .appearance-toggle {
    font-family: inherit;
    font-size: 11px;
    color: var(--color-muted);
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    padding: 3px 10px;
    cursor: pointer;
    transition: color .15s ease, border-color .15s ease;
  }

  .appearance-toggle:hover,
  .appearance-toggle[aria-pressed="true"] {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }

  p {
    font-size: 11px;
    color: var(--color-label);
    margin: 0;
  }

  @media (max-width: 600px) {
    [data-module="footer"] {
      padding: 16px var(--gutter-mobile);
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>
