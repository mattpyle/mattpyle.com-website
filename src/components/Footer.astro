---
const year = new Date().getFullYear();
---

<footer data-module="footer">
  <nav aria-label="Social links">
    <a href="https://github.com/mattpyle" target="_blank" rel="noopener noreferrer">GitHub</a>
    <a href="https://linkedin.com/in/matt-pyle" target="_blank" rel="noopener noreferrer">LinkedIn</a>
  </nav>
  <p>© {year} Matt Pyle</p>
</footer>

<style>
  [data-module="footer"] {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 18px 40px;
    border-top: 1px solid var(--color-border);
    width: 100%;
    max-width: 1080px;
    margin: 0 auto;
  }

  nav {
    display: flex;
    gap: 18px;
  }

  nav a {
    font-size: 11px;
    color: var(--color-muted);
    text-decoration: none;
    transition: color .15s ease;
  }

  nav a:hover { color: var(--color-accent); }

  p {
    font-size: 11px;
    color: var(--color-label);
    margin: 0;
  }

  @media (max-width: 600px) {
    [data-module="footer"] {
      padding: 16px 20px;
      flex-direction: column;
      align-items: flex-start;
      gap: 10px;
    }
  }
</style>
