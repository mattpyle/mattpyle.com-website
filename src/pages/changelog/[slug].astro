---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import Layout from '../../layouts/Layout.astro';
import { showDrafts } from '../../lib/show-drafts';

export async function getStaticPaths() {
  const entries = (await getCollection('changelog', ({ data }) => showDrafts || !data.draft))
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

  return entries.map((entry, index) => ({
    params: { slug: entry.id },
    props: {
      entry,
      // Entries are sorted newest-first: "previous" moves backward in the
      // chronology (older), while "next" moves forward (newer).
      prev: entries[index + 1] ?? null,
      next: entries[index - 1] ?? null,
    },
  }));
}

const { entry, prev, next } = Astro.props;
const { Content } = await render(entry);

function formatDate(date: Date): string {
  const d = date.getUTCDate().toString().padStart(2, '0');
  const m = date.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const y = date.getUTCFullYear();
  return `${d} ${m} ${y}`;
}

const { title, summary, date, updated, tags, type, significance, hero, draft } = entry.data;
const sigLabel = significance.toUpperCase();
const markdownUrl = `/changelog/${entry.id}.md`;
---

<Layout
  title={title}
  description={summary}
  type="article"
  image={`/og/changelog/${entry.id}.png`}
  publishedTime={date}
  modifiedTime={updated}
  noindex={draft}
  markdownAlternate={markdownUrl}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Changelog', url: '/changelog' },
    { name: title, url: `/changelog/${entry.id}` },
  ]}
>
  <article data-module="article">

    {showDrafts && draft && (
      <p class="draft-banner" role="status">DRAFT — not published, preview only</p>
    )}

    <a href="/changelog" class="back-link">← ALL CHANGELOG</a>

    <header>
      <div class="changelog-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        <span class="sig-chip">
          <span class={`sig-dot sig-dot--${significance}`} aria-hidden="true"></span>{sigLabel}
        </span>
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="type-pill">{type}</span>
      </div>
      <h1 class="page-title page-title--article">{title}</h1>
      <p class="article-dek page-intro">{summary}</p>
      <ul role="list" class="article-tags">
        {tags.map(tag => <li class="tag-pill">{tag}</li>)}
      </ul>
    </header>

    {hero && (
      <figure class="hero">
        <Image src={hero} alt="" />
      </figure>
    )}

    <div class="prose">
      <Content />
    </div>

    <footer class="changelog-footer">
      <nav class="entry-navigation" aria-label="Changelog entry navigation">
        {(prev || next) && (
          <div class="entry-links">
            {prev && (
              <a href={`/changelog/${prev.id}`} class="entry-link entry-link--previous">
                <span class="entry-direction">
                  <span aria-hidden="true">←</span> Previous entry
                </span>
                <span class="entry-title">{prev.data.title}</span>
              </a>
            )}
            {next && (
              <a href={`/changelog/${next.id}`} class="entry-link entry-link--next">
                <span class="entry-direction">
                  Next entry <span aria-hidden="true">→</span>
                </span>
                <span class="entry-title">{next.data.title}</span>
              </a>
            )}
          </div>
        )}
        <a href="/changelog" class="changelog-index-link">
          <span class="index-mark" aria-hidden="true"><i></i><i></i><i></i></span>
          View all changelog entries
        </a>
      </nav>
    </footer>

  </article>
</Layout>

<style>
  [data-module="article"] {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 56px var(--gutter) 80px;
  }

  .draft-banner {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid var(--color-accent);
    padding: 8px 14px;
    margin: 0 0 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-muted);
    margin-bottom: 28px;
  }

  .back-link:hover { color: var(--color-accent); }

  header { margin-bottom: 22px; }

  /* ── Changelog meta row ─────────────────────────────────────────────────── */
  .changelog-meta {
    display: flex;
    align-items: center;
    gap: 14px;
    row-gap: 8px;
    margin-bottom: 18px;
    flex-wrap: wrap;
  }

  .changelog-meta time,
  .meta-sep {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-label);
  }

  .meta-sep { color: #cabfa9; }

  .sig-chip {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-muted);
  }

  .sig-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .sig-dot--major { background: var(--color-sig-major); }
  .sig-dot--minor { background: var(--color-sig-minor); }
  .sig-dot--patch { background: var(--color-sig-patch); }

  .type-pill {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .06em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid rgba(122, 46, 46, .25);
    padding: 2px 9px;
    border-radius: 999px;
  }

  h1 { margin: 0 0 16px; }
  .article-dek { margin: 0 0 20px; }

  .article-tags {
    list-style: none;
    display: flex;
    gap: 8px;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-label);
    border: 1px solid var(--color-border);
    padding: 3px 9px;
    border-radius: 999px;
  }

  /* ── Optional hero ──────────────────────────────────────────────────────── */
  .hero {
    margin: 0 0 32px;
  }

  .hero :global(img) {
    display: block;
    width: 100%;
    height: auto;
    border: 1px solid var(--color-border);
  }

  /* ── Footer navigation ──────────────────────────────────────────────────── */
  .changelog-footer {
    margin-top: 48px;
  }

  .entry-navigation {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .entry-links {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .entry-link {
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-width: 0;
    min-height: 112px;
    padding: 20px 22px;
    background: transparent;
    text-decoration: none;
    transition: background-color .15s ease;
  }

  .entry-link--previous { grid-column: 1; }

  .entry-link--next {
    grid-column: 2;
    border-left: 1px solid var(--color-border);
    text-align: right;
  }

  .entry-link:hover { background: var(--color-accent-wash); }

  .entry-direction {
    display: flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    line-height: 1.4;
    text-transform: uppercase;
    color: var(--color-accent);
  }

  .entry-link--next .entry-direction { justify-content: flex-end; }

  .entry-title {
    display: block;
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 600;
    line-height: 1.35;
    color: var(--color-heading);
    transition: color .12s ease;
  }

  .entry-link:hover .entry-title { color: var(--color-accent); }

  .changelog-index-link {
    display: inline-flex;
    align-items: center;
    align-self: center;
    gap: 9px;
    padding: 4px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .12em;
    line-height: 1.4;
    text-transform: uppercase;
    color: var(--color-muted);
  }

  .changelog-index-link:hover { color: var(--color-accent); }

  .index-mark {
    display: inline-flex;
    flex-direction: column;
    gap: 2px;
    width: 12px;
  }

  .index-mark i {
    display: block;
    width: 100%;
    height: 1px;
    background: currentColor;
  }

  @media (max-width: 600px) {
    [data-module="article"] { padding: 40px var(--gutter-mobile) 56px; }
  }

  @media (max-width: 520px) {
    .entry-links { grid-template-columns: 1fr; }

    .entry-link--previous,
    .entry-link--next { grid-column: 1; }

    .entry-link--next { border-left: 0; }

    .entry-link--previous + .entry-link--next {
      border-top: 1px solid var(--color-border);
    }
  }
</style>
