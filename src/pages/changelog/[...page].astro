---
import type { GetStaticPaths, Page } from 'astro';
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ChangelogLedger from '../../components/ChangelogLedger.astro';
import { showDrafts } from '../../lib/show-drafts';
import { compareChangelogEntries } from '../../lib/changelog-order';

export const getStaticPaths = (async ({ paginate }) => {
  // Entries per ledger page. The year grouping is the visual scaffold; this is the
  // scaling one. Page 1 lives at /changelog (the rest param is undefined there);
  // older pages are /changelog/2, /changelog/3, … Tune this one number to taste —
  // nothing else needs to change. Kept high so the archive stays a single page until
  // the log actually grows (see CLAUDE.md "The /changelog collection"). Defined inside
  // getStaticPaths because Astro runs it in an isolated scope that can't see module
  // frontmatter consts.
  const PAGE_SIZE = 20;
  const entries = (await getCollection('changelog', ({ data }) => showDrafts || !data.draft))
    .sort(compareChangelogEntries);
  return paginate(entries, { pageSize: PAGE_SIZE });
}) satisfies GetStaticPaths;

type Entry = Awaited<ReturnType<typeof getCollection<'changelog'>>>[number];
const { page } = Astro.props as { page: Page<Entry> };

const legend = [
  { significance: 'major', label: 'MAJOR' },
  { significance: 'minor', label: 'MINOR' },
  { significance: 'patch', label: 'PATCH' },
] as const;

// "showing X of Y": cumulative count through the current page. page.end is a
// 0-indexed inclusive index into the full list, so +1 is the running total shown.
const shownThrough = page.end + 1;
const isFirst = page.currentPage === 1;

const description = "What's shipped on this site — launches, features, and the occasional experiment.";
const breadcrumbUrl = isFirst ? '/changelog' : `/changelog/${page.currentPage}`;
---

<Layout
  title={isFirst ? 'Changelog' : `Changelog — page ${page.currentPage}`}
  description={description}
  breadcrumbs={[{ name: 'Home', url: '/' }, { name: 'Changelog', url: breadcrumbUrl }]}
>
  <div class="changelog-shell">
    <header class="changelog-header">
      <p class="header-eyebrow">Changelog</p>
      <h1 class="page-title">Changelog</h1>
      <p class="header-subtitle page-intro">{description}</p>
    </header>

    <div class="legend" role="group" aria-label="Significance key">
      <span class="legend-label">SIGNIFICANCE</span>
      {legend.map(({ significance, label }) => (
        <span class="legend-item">
          <span class={`sig-dot sig-dot--${significance}`} aria-hidden="true"></span>{label}
        </span>
      ))}
    </div>

    <ChangelogLedger entries={page.data} />

    <nav class="lg-footer" aria-label="Changelog pagination">
      <div class="lg-pagelinks">
        {page.url.prev && (
          <a href={page.url.prev} class="lg-pagelink">← NEWER ENTRIES</a>
        )}
        {page.url.next && (
          <a href={page.url.next} class="lg-pagelink">LOAD OLDER ENTRIES →</a>
        )}
      </div>
      <span class="lg-count">showing {shownThrough} of {page.total}</span>
    </nav>
  </div>
</Layout>

<style>
  .changelog-shell {
    max-width: 860px;
    margin: 0 auto;
    padding: 64px var(--gutter) 72px;
  }

  .changelog-header { margin-bottom: 22px; }

  .header-eyebrow {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .16em;
    color: var(--color-label);
    margin: 0 0 16px;
    text-transform: uppercase;
  }

  .page-title { margin: 0 0 14px; }
  .header-subtitle { margin: 0 0 22px; }

  /* ── Significance legend ────────────────────────────────────────────────── */
  .legend {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 8px 18px;
    padding: 12px 0 4px;
    border-top: 1px solid var(--color-border);
    margin-bottom: 12px;
  }

  .legend-label {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: .14em;
    color: var(--color-muted);
  }

  .legend-item {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .08em;
    color: var(--color-muted);
  }

  .sig-dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
    display: inline-block;
  }

  .sig-dot--major { background: var(--color-sig-major); }
  .sig-dot--minor { background: var(--color-sig-minor); }
  .sig-dot--patch { background: var(--color-sig-patch); }

  /* ── Footer: pagination + count ─────────────────────────────────────────── */
  .lg-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
    padding: 22px 0 0;
    margin-top: 8px;
    border-top: 1px solid var(--color-border);
  }

  .lg-pagelinks {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }

  .lg-pagelink {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-accent);
  }

  .lg-pagelink:hover { color: var(--color-accent-hover); }

  .lg-count {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--color-muted);
  }

  @media (max-width: 600px) {
    .changelog-shell { padding: 40px var(--gutter-mobile) 56px; }
  }
</style>
