---
import Layout from '../layouts/Layout.astro';
import { SCORECARD, SCORECARD_HISTORY } from '../data/scorecard';

const currentPasses = SCORECARD.metrics.filter(metric => metric.status === 'Pass').length;
const historyPageSize = 20;

function shortMetricName(name: string): string {
  if (name === 'Accessibility') return 'A11y';
  if (name === 'Agentic Browsing') return 'Agents';
  return name;
}
---

<Layout title="Scorecard" description={SCORECARD.description}>
  <div class="scorecard-shell" data-module="scorecard">
    <header class="scorecard-header">
      <p class="eyebrow">Public scorecard · live web</p>
      <h1 class="page-title">Scorecard</h1>
      <p class="description page-intro">
        The latest verified scores, followed by every live-network run we have recorded.
      </p>
    </header>

    <section class="latest-run" aria-labelledby="latest-run-title">
      <header class="run-header">
        <div>
          <p class="section-label">Latest run</p>
          <h2 id="latest-run-title">
            <time datetime={SCORECARD.verified.iso}>{SCORECARD.verified.label}</time>
          </h2>
          {SCORECARD.verified.timestamp && (
            <time class="latest-time" datetime={SCORECARD.verified.timestamp}>
              {SCORECARD.verified.timestamp}
            </time>
          )}
        </div>
        <p class="run-verdict">
          <span class="verdict-mark" aria-hidden="true"></span>
          <span><strong>{currentPasses} of {SCORECARD.metrics.length}</strong> gates passing</span>
        </p>
      </header>

      <div class="current-scores">
        {SCORECARD.metrics.map(({ name, value, maximum, status, description }) => (
          <article class={`current-score current-score--${status.toLowerCase()}`}>
            <div class="score-heading">
              <h3>{name}</h3>
              <span class={`status status--${status.toLowerCase()}`}>
                <span class="status-dot" aria-hidden="true"></span>{status}
              </span>
            </div>
            <p class="score-value">
              <span>{value}</span><small>/{maximum}</small>
            </p>
            <p class="score-description">{description}</p>
          </article>
        ))}
      </div>

      <div class="run-notes">
        <dl class="verification">
          <div>
            <dt>Scope</dt>
            <dd>{SCORECARD.scope}</dd>
          </div>
          <div>
            <dt>Tools</dt>
            <dd>{SCORECARD.tools.join(' · ')}</dd>
          </div>
          <div>
            <dt>Entry</dt>
            <dd>{SCORECARD.entry}</dd>
          </div>
        </dl>
        <p class="current-commentary">
          The lowest result across the tested pages is shown for each category. A pass means the
          category met its existing scorecard rule, not that the site is free of defects.
        </p>
      </div>
    </section>

    <section class="history" aria-labelledby="history-title">
      <header class="history-header">
        <div>
          <p class="section-label">Archive</p>
          <h2 id="history-title">Run history</h2>
        </div>
        <p>Newest first · {historyPageSize} runs per page</p>
      </header>

      <div class="history-columns" aria-hidden="true">
        <span>Run</span>
        {SCORECARD.metrics.map(metric => <span>{shortMetricName(metric.name)}</span>)}
        <span></span>
      </div>

      <div class="history-list">
        {SCORECARD_HISTORY.map(run => {
          const passes = run.metrics.filter(metric => metric.status === 'Pass').length;
          return (
            <details class="history-run" id={`run-${run.id}`}>
              <summary>
                <span class="history-date">
                  <time datetime={run.verified.iso}>{run.verified.label}</time>
                  {run.verified.timestamp && (
                    <time class="history-timestamp" datetime={run.verified.timestamp}>
                      {run.verified.timestamp}
                    </time>
                  )}
                </span>

                {run.metrics.map(metric => (
                  <span
                    class="history-metric"
                    role="group"
                    aria-label={`${metric.name}: ${metric.value} of ${metric.maximum}, ${metric.status}`}
                  >
                    <span aria-hidden="true" class="history-metric-label">{shortMetricName(metric.name)}</span>
                    <span aria-hidden="true" class="history-number">{metric.value}<small>/{metric.maximum}</small></span>
                    <span aria-hidden="true" class={`history-status history-status--${metric.status.toLowerCase()}`}>
                      <span class="status-dot" aria-hidden="true"></span>{metric.status}
                    </span>
                  </span>
                ))}

                <span class="history-toggle">
                  <span class="history-result">{passes}/{run.metrics.length}</span>
                  <span class="chevron" aria-hidden="true"></span>
                </span>
              </summary>

              <div class="history-detail">
                <dl>
                  <div>
                    <dt>Scope</dt>
                    <dd>{run.scope}</dd>
                  </div>
                  <div>
                    <dt>Tools</dt>
                    <dd>{run.tools.join(' · ')}</dd>
                  </div>
                  <div>
                    <dt>Entry</dt>
                    <dd>{run.entry}</dd>
                  </div>
                </dl>
                <p>{run.commentary}</p>
              </div>
            </details>
          );
        })}
      </div>

      <footer class="history-footer">
        <span>Showing all {SCORECARD_HISTORY.length} previous runs</span>
        <nav aria-label="Scorecard history pagination">
          <span class="page-link page-link--disabled" aria-disabled="true">← Newer</span>
          <span class="page-number" aria-current="page">Page 1</span>
          <span class="page-link page-link--disabled" aria-disabled="true">Older →</span>
        </nav>
      </footer>
    </section>
  </div>
</Layout>

<style>
  .scorecard-shell {
    max-width: 980px;
    margin: 0 auto;
    padding: 64px var(--gutter) 88px;
  }

  .scorecard-header { max-width: 720px; }

  .eyebrow {
    margin: 0 0 16px;
    color: var(--color-label);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .16em;
    text-transform: uppercase;
  }

  .description {
    margin: 18px 0 40px;
  }

  .latest-run {
    overflow: hidden;
    background: var(--color-card);
    border: 1px solid var(--color-border);
    border-top: 3px solid var(--color-heading);
    box-shadow: 0 16px 40px rgba(35, 31, 24, .045);
  }

  .run-header,
  .history-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 24px;
  }

  .run-header { padding: 24px 28px 22px; }

  .section-label {
    margin: 0 0 7px;
    color: var(--color-label);
    font-family: var(--font-mono);
    font-size: 9.5px;
    letter-spacing: .14em;
    text-transform: uppercase;
  }

  .run-header h2,
  .history-header h2 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: 27px;
    font-weight: 600;
    letter-spacing: -.015em;
    line-height: 1.1;
  }

  .latest-time {
    display: block;
    margin: 5px 0 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 8.5px;
  }

  .run-verdict {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    margin: 0 0 2px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 10.5px;
  }

  .run-verdict strong { color: var(--color-heading); font-weight: 600; }

  .verdict-mark {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-status-green);
    box-shadow: 0 0 0 4px rgba(92, 122, 83, .12);
  }

  .current-scores {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
  }

  .current-score {
    position: relative;
    min-width: 0;
    padding: 22px 20px 24px;
    border-right: 1px solid var(--color-border);
  }

  .current-score:last-child { border-right: 0; }

  .current-score::before {
    position: absolute;
    top: -1px;
    left: 0;
    width: 100%;
    height: 2px;
    background: var(--color-status-green);
    content: '';
  }

  .current-score--fail::before { background: var(--color-accent); }
  .current-score--partial::before { background: var(--color-sig-minor); }

  .score-heading {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 8px;
  }

  .score-heading h3 {
    margin: 0;
    color: var(--color-heading);
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: .06em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .status,
  .history-status {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    color: var(--color-status-green);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: .06em;
    line-height: 1.4;
    text-transform: uppercase;
  }

  .history-status { color: #48623f; }

  .status--fail,
  .history-status--fail { color: var(--color-accent); }

  .status--partial,
  .history-status--partial { color: var(--color-sig-minor); }

  .status-dot {
    width: 6px;
    height: 6px;
    flex: 0 0 auto;
    border-radius: 50%;
    background: currentColor;
  }

  .score-value {
    margin: 18px 0 13px;
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: 48px;
    font-weight: 600;
    letter-spacing: -.035em;
    line-height: .85;
    white-space: nowrap;
  }

  .score-value small,
  .history-number small {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0;
  }

  .score-description {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-system);
    font-size: 11.5px;
    line-height: 1.55;
  }

  .run-notes {
    display: grid;
    grid-template-columns: 1.35fr .65fr;
    gap: 28px;
    padding: 22px 28px 24px;
  }

  .verification {
    display: grid;
    grid-template-columns: .8fr 1.35fr 1fr;
    gap: 20px;
    margin: 0;
  }

  .verification div,
  .history-detail dl div { min-width: 0; }

  .verification dt,
  .history-detail dt {
    margin-bottom: 6px;
    color: var(--color-label);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: .12em;
    text-transform: uppercase;
  }

  .verification dd,
  .history-detail dd {
    margin: 0;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 9.5px;
    line-height: 1.5;
  }

  .current-commentary {
    margin: 0;
    padding-left: 18px;
    border-left: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-size: 12.5px;
    font-style: italic;
    line-height: 1.55;
  }

  .history { margin-top: 60px; }

  .history-header { margin-bottom: 20px; }

  .history-header > p {
    margin: 0 0 3px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 9.5px;
  }

  .history-columns,
  .history-run summary {
    display: grid;
    grid-template-columns: minmax(150px, 1.25fr) repeat(4, minmax(92px, 1fr)) 42px;
    gap: 14px;
    align-items: center;
  }

  .history-columns {
    padding: 0 16px 9px;
    color: var(--color-label);
    font-family: var(--font-mono);
    font-size: 8.5px;
    letter-spacing: .1em;
    text-transform: uppercase;
  }

  .history-list { border-top: 2px solid var(--color-heading); }

  .history-run { border-bottom: 1px solid var(--color-border); }

  .history-run summary {
    min-height: 86px;
    padding: 14px 16px;
    cursor: pointer;
    list-style: none;
    transition: background .12s ease;
  }

  .history-run summary::-webkit-details-marker { display: none; }
  .history-run summary:hover { background: var(--color-accent-wash); }
  .history-run summary:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: -2px;
  }

  .history-date { display: flex; flex-direction: column; gap: 5px; }

  .history-date time {
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: 16px;
    font-weight: 600;
  }

  .history-timestamp {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 8.5px;
    line-height: 1.35;
  }

  .history-metric {
    display: flex;
    min-width: 0;
    flex-direction: column;
    align-items: flex-start;
    gap: 5px;
  }

  .history-metric-label { display: none; }

  .history-number {
    color: var(--color-heading);
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    letter-spacing: -.02em;
    line-height: 1;
  }

  .history-toggle {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 9px;
  }

  .history-result {
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 8.5px;
  }

  .chevron {
    width: 7px;
    height: 7px;
    border-right: 1px solid var(--color-label);
    border-bottom: 1px solid var(--color-label);
    transform: rotate(45deg) translateY(-2px);
    transition: transform .15s ease;
  }

  .history-run[open] .chevron { transform: rotate(225deg) translate(-2px, -1px); }

  .history-detail {
    display: grid;
    grid-template-columns: 1.35fr .65fr;
    gap: 28px;
    padding: 18px 16px 22px;
    background: rgba(255, 255, 255, .45);
    border-top: 1px solid var(--color-border);
  }

  .history-detail dl {
    display: grid;
    grid-template-columns: .8fr 1.35fr 1fr;
    gap: 20px;
    margin: 0;
  }

  .history-detail > p {
    margin: 0;
    padding-left: 18px;
    border-left: 1px solid var(--color-border);
    color: var(--color-muted);
    font-family: var(--font-serif);
    font-size: 12.5px;
    font-style: italic;
    line-height: 1.55;
  }

  .history-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 20px;
    padding-top: 18px;
    color: var(--color-muted);
    font-family: var(--font-mono);
    font-size: 9.5px;
  }

  .history-footer nav { display: flex; align-items: center; gap: 16px; }

  .page-link {
    color: var(--color-accent);
    font-size: 9px;
    letter-spacing: .07em;
    text-transform: uppercase;
  }

  .page-link--disabled { color: var(--color-border); }

  .page-number {
    padding: 3px 8px;
    border: 1px solid var(--color-border);
    color: var(--color-heading);
  }

  @media (max-width: 820px) {
    .current-scores { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .current-score:nth-child(2) { border-right: 0; }
    .current-score:nth-child(-n + 2) { border-bottom: 1px solid var(--color-border); }
    .history-columns,
    .history-run summary {
      grid-template-columns: minmax(132px, 1.25fr) repeat(4, minmax(70px, 1fr)) 34px;
      gap: 9px;
    }
  }

  @media (max-width: 650px) {
    .scorecard-shell {
      padding: 40px var(--gutter-mobile) 60px;
    }

    .description { margin-bottom: 32px; }
    .run-header { align-items: flex-start; padding: 20px; }
    .run-verdict { margin-top: 5px; }
    .current-score { padding: 20px; }
    .score-value { font-size: 44px; }

    .run-notes,
    .history-detail { grid-template-columns: 1fr; gap: 18px; padding: 20px; }
    .verification {
      grid-template-columns: 1fr 1.4fr;
    }
    .verification div:last-child { grid-column: 1 / -1; }
    .current-commentary,
    .history-detail > p { padding: 16px 0 0; border-top: 1px solid var(--color-border); border-left: 0; }

    .history { margin-top: 48px; }
    .history-header { align-items: flex-start; }
    .history-header > p { max-width: 120px; text-align: right; line-height: 1.5; }
    .history-columns { display: none; }
    .history-list { border-top-width: 2px; }

    .history-run summary {
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px 12px;
      padding: 18px 8px;
    }

    .history-date {
      grid-column: 1 / -1;
      padding-right: 54px;
    }

    .history-metric { padding-top: 10px; border-top: 1px solid var(--color-border); }
    .history-metric-label {
      display: block;
      color: var(--color-label);
      font-family: var(--font-mono);
      font-size: 8px;
      letter-spacing: .09em;
      text-transform: uppercase;
    }

    .history-toggle {
      position: absolute;
      top: 22px;
      right: 10px;
    }

    .history-run summary { position: relative; }
    .history-detail { padding: 18px 8px 22px; }
    .history-detail dl { grid-template-columns: 1fr 1.4fr; }
    .history-detail dl div:last-child { grid-column: 1 / -1; }
    .history-footer { align-items: flex-start; flex-direction: column; }
  }

  @media (max-width: 410px) {
    .run-header { flex-direction: column; gap: 14px; }
    .current-scores { grid-template-columns: 1fr; }
    .current-score { border-right: 0; border-bottom: 1px solid var(--color-border); }
    .current-score:last-child { border-bottom: 0; }
    .score-description { max-width: 34ch; }
  }

  @media (prefers-reduced-motion: reduce) {
    .history-run summary,
    .chevron { transition: none; }
  }
</style>
