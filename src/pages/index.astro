---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import RecentWriting from '../components/RecentWriting.astro';
import RetroHomeFurniture from '../components/RetroHomeFurniture.astro';
import { getCollection } from 'astro:content';
import { showDrafts } from '../lib/show-drafts';
import { compareChangelogEntries } from '../lib/changelog-order';

const recentArticles = (
  await getCollection('writing', ({ data }) => showDrafts || !data.draft)
)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 2);

const activityItems = (
  await getCollection('changelog', ({ data }) => showDrafts || !data.draft)
)
  .sort(compareChangelogEntries)
  .slice(0, 4)
  .map(({ id, data }) => ({
    date: data.date,
    href: `/changelog/${id}`,
    title: data.title,
    type: data.type,
    significance: data.significance,
  }));
---

<Layout
  title="Matt Pyle"
  fullTitle="Matt Pyle — Growth & PLG, in public"
  description="Growth marketer and hobbyist builder. Director of Growth at Temporal Technologies."
>
  <Hero activityItems={activityItems} />
  <RetroHomeFurniture />
  <RecentWriting articles={recentArticles} />
</Layout>
