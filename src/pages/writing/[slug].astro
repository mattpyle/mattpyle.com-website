---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { showDrafts } from '../../lib/show-drafts';

export async function getStaticPaths() {
  const articles = await getCollection('writing', ({ data }) => showDrafts || !data.draft);
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

function formatDate(date: Date): string {
  const d = date.getUTCDate().toString().padStart(2, '0');
  const m = date.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const y = date.getUTCFullYear();
  return `${d} ${m} ${y}`;
}

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}

const { title, date, updated, tags, description, featured, image, seoTitle, seoDescription } = article.data;
---

<Layout
  title={title}
  seoTitle={seoTitle}
  description={description}
  seoDescription={seoDescription}
  type="article"
  image={image ?? `/og/writing/${article.id}.png`}
  publishedTime={date}
  modifiedTime={updated}
  noindex={article.data.draft}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Writing', url: '/writing' },
    { name: title, url: `/writing/${article.id}` },
  ]}
>
  <article data-module="article">

    {showDrafts && article.data.draft && (
      <p class="draft-banner" role="status">DRAFT — not published, preview only</p>
    )}

    <a href="/writing" class="back-link">← ALL WRITING</a>

    <header>
      <div data-module="article-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {featured && <span class="featured-badge"><span aria-hidden="true">◆</span> FEATURED</span>}
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="read-time">{readingTime(article.body ?? '')}</span>
      </div>
      <h1 class="page-title page-title--article">{title}</h1>
      <p class="article-dek page-intro">{description}</p>
      <ul role="list" class="article-tags">
        {tags.map(tag => <li class="tag-pill">{tag}</li>)}
      </ul>
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/writing" class="back-link">← ALL WRITING</a>
    </footer>

  </article>
</Layout>

<style>
  [data-module="article"] {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 56px var(--gutter) 80px;
  }

  .draft-banner {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid var(--color-accent);
    padding: 8px 14px;
    margin: 0 0 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-muted);
    margin-bottom: 28px;
  }

  .back-link:hover { color: var(--color-accent); }

  header { margin-bottom: 40px; }

  [data-module="article-meta"] {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
    flex-wrap: wrap;
    row-gap: 8px;
  }

  [data-module="article-meta"] time,
  .meta-sep,
  .read-time {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-label);
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .12em;
    color: var(--color-accent);
  }

  h1 {
    margin: 0 0 18px;
  }

  .article-dek {
    margin: 0 0 20px;
  }

  .article-tags {
    list-style: none;
    display: flex;
    gap: 8px;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-label);
    border: 1px solid var(--color-border);
    padding: 3px 9px;
    border-radius: 999px;
  }

  /* ── Prose body ─────────────────────────────────────────────────────────── */

  .prose {
    font-family: var(--font-serif);
    font-size: 17.5px;
    line-height: 1.8;
    color: var(--color-text);
    display: flex;
    flex-direction: column;
    gap: 22px;
  }

  .prose :global(p)  { margin: 0; }

  .prose :global(h2) {
    font-family: var(--font-serif);
    font-size: 27px;
    font-weight: 600;
    line-height: 1.25;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-heading);
    margin: 22px 0 0;
  }

  .prose :global(h3) {
    font-family: var(--font-serif);
    font-size: 22px;
    font-weight: 600;
    line-height: 1.3;
    letter-spacing: 0;
    text-transform: none;
    color: var(--color-heading);
    margin: 14px 0 0;
  }

  .prose :global(strong) { font-weight: 600; color: var(--color-heading); }
  .prose :global(em)     { font-style: italic; }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--color-accent-underline);
    transition: text-decoration-color .15s ease;
  }

  .prose :global(a:hover) { text-decoration-color: var(--color-accent); }

  .prose :global(blockquote) {
    border-left: 2px solid var(--color-accent);
    margin: 0;
    padding: 4px 0 4px 20px;
    color: var(--color-muted);
    font-style: italic;
  }

  .prose :global(ul),
  .prose :global(ol) { margin: 0; padding-left: 24px; }
  .prose :global(li) { margin-bottom: 6px; }

  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: .875em;
    background: var(--color-surface-code);
    border: 1px solid var(--color-border);
    padding: 1px 5px;
    color: var(--color-accent);
  }

  .prose :global(pre) {
    margin: 0;
    overflow-x: auto;
    background: var(--color-surface-code);
    border: 1px solid var(--color-border);
    padding: 14px 16px;
    font-family: var(--font-mono);
    font-size: .875em;
    line-height: 1.6;
  }

  .prose :global(pre code) { background: none; border: none; padding: 0; }

  .prose :global(hr) {
    border: 0;
    border-top: 1px solid var(--color-border);
    margin: 8px 0;
  }

  .prose :global(figure)     { margin: 0; }
  .prose :global(img)        { display: block; max-width: 100%; height: auto; }
  .prose :global(figcaption) {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .04em;
    color: var(--color-muted);
    margin-top: 8px;
  }

  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-family: var(--font-mono);
    font-size: 14px;
    line-height: 1.5;
  }

  .prose :global(th),
  .prose :global(td) {
    text-align: left;
    padding: 8px 12px 8px 0;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .prose :global(thead th) {
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-label);
    font-weight: normal;
  }

  /* ── Article footer ─────────────────────────────────────────────────────── */

  .article-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .article-footer .back-link { margin-bottom: 0; }

  @media (max-width: 600px) {
    [data-module="article"] { padding: 40px var(--gutter-mobile) 56px; }
  }
</style>
