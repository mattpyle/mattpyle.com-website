---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import ArticleActions from '../../components/ArticleActions.astro';
import { showDrafts } from '../../lib/show-drafts';

export async function getStaticPaths() {
  const articles = await getCollection('writing', ({ data }) => showDrafts || !data.draft);
  return articles.map(article => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

function formatDate(date: Date): string {
  const d = date.getUTCDate().toString().padStart(2, '0');
  const m = date.toLocaleDateString('en-US', { month: 'short', timeZone: 'UTC' }).toUpperCase();
  const y = date.getUTCFullYear();
  return `${d} ${m} ${y}`;
}

function readingTime(body: string): string {
  const words = body.trim().split(/\s+/).length;
  return `${Math.max(1, Math.ceil(words / 200))} min read`;
}

const { title, date, updated, tags, description, featured, image, seoTitle, seoDescription } = article.data;
const markdownUrl = `/writing/${article.id}.md`;
const canonicalUrl = new URL(`/writing/${article.id}/`, Astro.site).toString();
---

<Layout
  title={title}
  seoTitle={seoTitle}
  description={description}
  seoDescription={seoDescription}
  type="article"
  image={image ?? `/og/writing/${article.id}.png`}
  publishedTime={date}
  modifiedTime={updated}
  noindex={article.data.draft}
  markdownAlternate={markdownUrl}
  breadcrumbs={[
    { name: 'Home', url: '/' },
    { name: 'Writing', url: '/writing' },
    { name: title, url: `/writing/${article.id}` },
  ]}
>
  <article data-module="article">

    {showDrafts && article.data.draft && (
      <p class="draft-banner" role="status">DRAFT — not published, preview only</p>
    )}

    <a href="/writing" class="back-link">← ALL WRITING</a>

    <header>
      <div data-module="article-meta">
        <time datetime={date.toISOString()}>{formatDate(date)}</time>
        {featured && <span class="featured-badge"><span aria-hidden="true">◆</span> FEATURED</span>}
        <span class="meta-sep" aria-hidden="true">·</span>
        <span class="read-time">{readingTime(article.body ?? '')}</span>
      </div>
      <h1 class="page-title page-title--article">{title}</h1>
      <p class="article-dek page-intro">{description}</p>
      <ul role="list" class="article-tags">
        {tags.map(tag => <li class="tag-pill">{tag}</li>)}
      </ul>
      <ArticleActions canonicalUrl={canonicalUrl} markdownUrl={markdownUrl} />
    </header>

    <div class="prose">
      <Content />
    </div>

    <footer class="article-footer">
      <a href="/writing" class="back-link">← ALL WRITING</a>
    </footer>

  </article>
</Layout>

<style>
  [data-module="article"] {
    max-width: var(--width-content);
    margin: 0 auto;
    padding: 56px var(--gutter) 80px;
  }

  .draft-banner {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .08em;
    text-transform: uppercase;
    color: var(--color-accent);
    background: var(--color-accent-tint);
    border: 1px solid var(--color-accent);
    padding: 8px 14px;
    margin: 0 0 24px;
  }

  .back-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-muted);
    margin-bottom: 28px;
  }

  .back-link:hover { color: var(--color-accent); }

  header { margin-bottom: 24px; }

  [data-module="article-meta"] {
    display: flex;
    align-items: center;
    gap: 14px;
    margin-bottom: 18px;
    flex-wrap: wrap;
    row-gap: 8px;
  }

  [data-module="article-meta"] time,
  .meta-sep,
  .read-time {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: .1em;
    color: var(--color-label);
  }

  .featured-badge {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: .12em;
    color: var(--color-accent);
  }

  h1 {
    margin: 0 0 18px;
  }

  .article-dek {
    margin: 0 0 20px;
  }

  .article-tags {
    list-style: none;
    display: flex;
    gap: 8px;
    margin: 0;
    padding: 0;
    flex-wrap: wrap;
  }

  .tag-pill {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--color-label);
    border: 1px solid var(--color-border);
    padding: 3px 9px;
    border-radius: 999px;
  }

  /* ── Prose body ───────────────────────────────────────────────────────────
     Lives in src/styles/global.css (loaded on every page via Layout) so the
     changelog entry page shares the identical treatment with no extra stylesheet
     request. Edit prose there, not here. */

  /* ── Article footer ─────────────────────────────────────────────────────── */

  .article-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--color-border);
  }

  .article-footer .back-link { margin-bottom: 0; }

  @media (max-width: 600px) {
    [data-module="article"] { padding: 40px var(--gutter-mobile) 56px; }
  }
</style>
