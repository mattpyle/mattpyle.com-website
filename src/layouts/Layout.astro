---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  /** Used verbatim as the <title>/og:title/twitter:title, skipping the "— Matt Pyle" suffix. For pages (e.g. the homepage) whose title already is the full entity-disambiguating string. */
  fullTitle?: string;
  /** Short override for <title>/og:title/twitter:title only — `title` still feeds the JSON-LD headline. Use when the on-page title is too long for SERPs (~60 chars incl. " — Matt Pyle"). */
  seoTitle?: string;
  description?: string;
  /** Short override for <meta description>/og/twitter descriptions only — `description` still feeds the visible dek and JSON-LD. Use when the on-page description exceeds ~155 chars. */
  seoDescription?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  breadcrumbs?: Breadcrumb[];
  noindex?: boolean;
}

const {
  title = 'Matt Pyle',
  fullTitle,
  seoTitle,
  description = 'Growth marketer and hobbyist builder. Director of Growth at Temporal Technologies.',
  seoDescription,
  type = 'website',
  image,
  publishedTime,
  modifiedTime,
  breadcrumbs,
  noindex = false,
} = Astro.props;

const headTitleBase = seoTitle ?? title;
const pageTitle = fullTitle ?? (headTitleBase === 'Matt Pyle' ? headTitleBase : `${headTitleBase} — Matt Pyle`);
const metaDescription = seoDescription ?? description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = new URL('/', Astro.site).toString();
const personId = `${siteURL}#person`;
const websiteId = `${siteURL}#website`;

// Per-post `image` (see writing/[slug].astro) falls back to this sitewide 1200x630 share card.
const ogImageURL = new URL(image ?? '/og-fallback.png', Astro.site);
const twitterCard = image ? 'summary_large_image' : 'summary';

// Person + WebSite ship on every page so the entity resolves the same way everywhere.
// sameAs matches exactly the two links in Footer.astro / AboutGrid.astro — GitHub + LinkedIn
// only, no X/Twitter (see CLAUDE.md: that's a deliberate entity statement, not an omission).
const jsonLdGraph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': personId,
    name: 'Matt Pyle',
    url: siteURL,
    jobTitle: 'Director of Growth',
    worksFor: { '@type': 'Organization', name: 'Temporal Technologies' },
    sameAs: ['https://github.com/mattpyle', 'https://linkedin.com/in/matt-pyle'],
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: siteURL,
    name: 'Matt Pyle',
    description: 'Growth marketer and hobbyist builder. Director of Growth at Temporal Technologies.',
    publisher: { '@id': personId },
  },
];

if (type === 'article' && publishedTime) {
  jsonLdGraph.push({
    '@type': 'BlogPosting',
    '@id': `${canonicalURL}#article`,
    headline: title,
    description,
    image: ogImageURL.toString(),
    url: canonicalURL.toString(),
    datePublished: publishedTime.toISOString(),
    dateModified: (modifiedTime ?? publishedTime).toISOString(),
    author: { '@id': personId },
    publisher: { '@id': personId },
    mainEntityOfPage: canonicalURL.toString(),
  });
}

if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLdGraph.push({
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.url, Astro.site).toString(),
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf7f0" />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:site_name" content="Matt Pyle" />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImageURL} />
    <link rel="alternate" type="application/rss+xml" title="Matt Pyle — Writing" href={new URL('/rss.xml', Astro.site)} />
    <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-latin.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Nav />
    <main class="site-main" id="main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style>
  .site-main { flex: 1; }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 12px;
    z-index: 100;
    padding: 10px 16px;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    transition: top .15s ease;
  }

  .skip-link:focus {
    top: 72px;
  }
</style>
