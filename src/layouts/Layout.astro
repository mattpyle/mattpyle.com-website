---
import '../styles/global.css';
import '../styles/retro.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import WebMCP from '../components/WebMCP.astro';
import AppearanceBanner from '../components/AppearanceBanner.astro';
import AppearanceToast from '../components/AppearanceToast.astro';
import AppearanceUI from '../components/AppearanceUI.astro';

interface Breadcrumb {
  name: string;
  url: string;
}

interface Props {
  title?: string;
  /** Used verbatim as the <title>/og:title/twitter:title, skipping the "— Matt Pyle" suffix. For pages (e.g. the homepage) whose title already is the full entity-disambiguating string. */
  fullTitle?: string;
  /** Short override for <title>/og:title/twitter:title only — `title` still feeds the JSON-LD headline. Use when the on-page title is too long for SERPs (~60 chars incl. " — Matt Pyle"). */
  seoTitle?: string;
  description?: string;
  /** Short override for <meta description>/og/twitter descriptions only — `description` still feeds the visible dek and JSON-LD. Use when the on-page description exceeds ~155 chars. */
  seoDescription?: string;
  type?: 'website' | 'article';
  image?: string;
  publishedTime?: Date;
  modifiedTime?: Date;
  breadcrumbs?: Breadcrumb[];
  noindex?: boolean;
  /** Path to this page's raw-markdown variant (e.g. `/writing/<slug>.md`) — see src/pages/writing/[slug].md.ts. */
  markdownAlternate?: string;
  /** ISO 8601 duration (e.g. "PT6M") for the BlogPosting `timeRequired` field — see src/lib/reading-time.ts. Article pages only. */
  readingTimeISO8601?: string;
}

const {
  title = 'Matt Pyle',
  fullTitle,
  seoTitle,
  description = 'Growth marketer and hobbyist builder. Director of Growth at Temporal Technologies.',
  seoDescription,
  type = 'website',
  image,
  publishedTime,
  modifiedTime,
  breadcrumbs,
  noindex = false,
  markdownAlternate,
  readingTimeISO8601,
} = Astro.props;

const headTitleBase = seoTitle ?? title;
const pageTitle = fullTitle ?? (headTitleBase === 'Matt Pyle' ? headTitleBase : `${headTitleBase} — Matt Pyle`);
const metaDescription = seoDescription ?? description;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const siteURL = new URL('/', Astro.site).toString();
const personId = `${siteURL}#person`;
const websiteId = `${siteURL}#website`;

// Route-derived default so every new section page (and any subdirectory under it)
// gets a correct BreadcrumbList for free — no per-page wiring required. Detail
// pages that need a human title instead of a raw slug (e.g. /writing/[slug]) pass
// an explicit `breadcrumbs` prop, which overrides this entirely. The homepage
// (empty path) intentionally gets no trail — it's the root, not a hierarchy leaf.
function humanizeSegment(segment: string): string {
  return segment
    .split(/[-_]/)
    .filter(Boolean)
    .map(word => word.charAt(0).toUpperCase() + word.slice(1))
    .join(' ');
}

function defaultBreadcrumbs(pathname: string): Breadcrumb[] | undefined {
  const segments = pathname.split('/').filter(Boolean);
  if (segments.length === 0) return undefined;

  const crumbs: Breadcrumb[] = [{ name: 'Home', url: '/' }];
  let path = '';
  for (const segment of segments) {
    path += `/${segment}`;
    crumbs.push({ name: humanizeSegment(segment), url: path });
  }
  return crumbs;
}

const resolvedBreadcrumbs = breadcrumbs ?? defaultBreadcrumbs(Astro.url.pathname);

// Per-post `image` (see writing/[slug].astro) falls back to this sitewide 1200x630 share card.
const ogImageURL = new URL(image ?? '/og-fallback.png', Astro.site);
// Twitter's own crop (1200x675, 16:9) — only the sitewide default needs a distinct asset;
// per-post images are already sized right for both tags.
const twitterImageURL = new URL(image ?? '/og-fallback-twitter.png', Astro.site);
// Every page now has a real large share image, so this is always the large card.
const twitterCard = 'summary_large_image';

// Person + WebSite ship on every page so the entity resolves the same way everywhere.
// sameAs matches exactly the two links in Footer.astro / AboutGrid.astro — GitHub + LinkedIn
// only, no X/Twitter (see CLAUDE.md: that's a deliberate entity statement, not an omission).
const jsonLdGraph: Record<string, unknown>[] = [
  {
    '@type': 'Person',
    '@id': personId,
    name: 'Matt Pyle',
    url: siteURL,
    jobTitle: 'Director of Growth',
    worksFor: { '@type': 'Organization', name: 'Temporal Technologies' },
    sameAs: ['https://github.com/mattpyle', 'https://linkedin.com/in/matt-pyle'],
  },
  {
    '@type': 'WebSite',
    '@id': websiteId,
    url: siteURL,
    name: 'Matt Pyle',
    description: 'Growth marketer and hobbyist builder. Director of Growth at Temporal Technologies.',
    publisher: { '@id': personId },
  },
];

if (type === 'article' && publishedTime) {
  jsonLdGraph.push({
    '@type': 'BlogPosting',
    '@id': `${canonicalURL}#article`,
    headline: title,
    description,
    image: ogImageURL.toString(),
    url: canonicalURL.toString(),
    datePublished: publishedTime.toISOString(),
    dateModified: (modifiedTime ?? publishedTime).toISOString(),
    author: { '@id': personId },
    publisher: { '@id': personId },
    mainEntityOfPage: canonicalURL.toString(),
    ...(readingTimeISO8601 ? { timeRequired: readingTimeISO8601 } : {}),
  });
}

if (resolvedBreadcrumbs && resolvedBreadcrumbs.length > 0) {
  jsonLdGraph.push({
    '@type': 'BreadcrumbList',
    itemListElement: resolvedBreadcrumbs.map((crumb, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: crumb.name,
      item: new URL(crumb.url, Astro.site).toString(),
    })),
  });
}

const jsonLd = { '@context': 'https://schema.org', '@graph': jsonLdGraph };
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    {/*
      Pre-paint appearance apply — a genuine inline (not module, not deferred)
      script so it runs synchronously, before the render-blocking stylesheets
      below are applied, and before first paint. This is what stops a returning
      retro visitor from seeing a flash of modern. is:inline keeps it literally
      inline (not bundled to an external file); security.csp in astro.config.mjs
      still SHA-256 hashes its content into the meta CSP automatically, so it's
      not an unhashed inline script.

      Duplicates the storage-key read from src/lib/appearance.mjs rather than
      importing it: a classic inline script can't use ES import, and a type=module
      script is deferred until after parsing — too late to beat first paint. Keep
      the key ('mattpyle:appearance') and the allowed value ('retro') in sync with
      appearance.mjs by hand; there is no way to share the constant here.
    */}
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem('mattpyle:appearance') === 'retro') {
            document.documentElement.dataset.appearance = 'retro';
          }
        } catch (e) {}
      })();
    </script>
    {/*
      Chrome WebMCP origin trial — bound to https://www.mattpyle.com (the canonical host; the apex
      308s to it) and EXPIRES 2026-11-17, after which Chrome ignores it and the tools in
      src/components/WebMCP.astro simply stop registering. That is a silent, harmless degradation —
      the site is unaffected either way — so nothing here needs guarding. Delete this line to end the
      trial early. Not a secret: origin-trial tokens are public by design.
    */}
    <meta http-equiv="origin-trial" content="Av/hVYhbhRGKIRl8KYjJftHmGKj2yeR3JjDgVDdWBIBPOSUM3H+VkG1Ad+18IHvy80DVhk8b/cMXtqL2wk4u6gsAAABQeyJvcmlnaW4iOiJodHRwczovL3d3dy5tYXR0cHlsZS5jb206NDQzIiwiZmVhdHVyZSI6IldlYk1DUCIsImV4cGlyeSI6MTc5NDg3MzYwMH0=" />
    <meta name="description" content={metaDescription} />
    {noindex && <meta name="robots" content="noindex" />}
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <meta name="theme-color" content="#faf7f0" />
    <title>{pageTitle}</title>

    <!-- Open Graph -->
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:image" content={ogImageURL} />
    {/* Hardcoded, not derived: the fallback and every generated per-post image are always 1200x630. */}
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Matt Pyle" />
    {type === 'article' && publishedTime && (
      <meta property="article:published_time" content={publishedTime.toISOString()} />
    )}
    {type === 'article' && modifiedTime && (
      <meta property="article:modified_time" content={modifiedTime.toISOString()} />
    )}

    <!-- Twitter Card -->
    <meta name="twitter:card" content={twitterCard} />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={twitterImageURL} />
    <link rel="alternate" type="application/rss+xml" title="Matt Pyle — Writing" href={new URL('/rss.xml', Astro.site)} />
    {markdownAlternate && (
      <link rel="alternate" type="text/markdown" href={new URL(markdownAlternate, Astro.site)} />
    )}
    <link rel="preload" href="/fonts/jetbrains-mono-latin.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/source-serif-4-latin.woff2" as="font" type="font/woff2" crossorigin />
    <ClientRouter />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <AppearanceBanner />
    <Nav />
    <main class="site-main" id="main">
      <slot />
    </main>
    <Footer />
    <AppearanceToast />
    <AppearanceUI />
    {/*
      MUST stay in <body>. This renders a <vercel-speed-insights> custom element, and a custom
      element inside <head> makes the HTML parser close the head early — which pushed Astro's
      generated CSP <meta> into the body, where Chrome ignores it ("delivered via a <meta> element
      outside the document's <head>"). That silently disabled script-src sitewide in production.
      Anything non-head-legal (custom elements, divs) belongs here, not up there.
    */}
    <SpeedInsights />
    <WebMCP />
  </body>
</html>

<style>
  .site-main { flex: 1; }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 12px;
    z-index: 100;
    padding: 10px 16px;
    background: var(--color-accent);
    color: var(--color-bg);
    font-family: var(--font-mono);
    font-size: 13px;
    text-decoration: none;
    transition: top .15s ease;
  }

  .skip-link:focus {
    top: 72px;
  }
</style>
